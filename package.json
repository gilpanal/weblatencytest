{
  "name": "@hi-audio/latency-test",
  "version": "1.0.0",
  "description": "Web Component for measuring browser round-trip audio latency using MLS, chirp, or Golay signals.",
  "scripts": {
    "dev": "parcel --no-cache src/*.html",
    "build": "parcel build 'src/*.html'",
    "predeploy": "rm -rf dist && parcel build 'src/*.html' --public-url ./",
    "deploy": "gh-pages -d dist",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/idsinge/rountriplatencytest-webcomponent.git"
  },
  "keywords": ["web-component", "audio", "latency", "mls", "audioworklet", "webaudio"],
  "author": "Hi-Audio",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/idsinge/rountriplatencytest-webcomponent/issues"
  },
  "homepage": "https://idsinge.github.io/rountriplatencytest-webcomponent/",
  "devDependencies": {
    "gh-pages": "^6.1.1",
    "parcel": "^2.12.0",
    "vitepress": "^1.6.0"
  }
}
